# ──────────────────────────────────────────────────────────────
# Nagarsetu — .env.example
# Copy to .env (and .env.local) and fill in. NEVER commit real values.
#
# Naming rules:
#   NEXT_PUBLIC_*  → exposed to the browser (web/Next.js). Safe-to-public only.
#   EXPO_PUBLIC_*  → exposed to the mobile client (Expo). Safe-to-public only.
#   everything else → SERVER-ONLY. Never ship to any client bundle.
# ──────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
# NOTE: do NOT set NODE_ENV manually. Next.js + Vercel set it for you
# (development for `next dev`, production for `next build` / Vercel
# production deploys, test for test runs). Setting NODE_ENV=development
# in a production build loads the React dev bundle and breaks prerender.
NEXT_PUBLIC_APP_URL=http://localhost:3000        # in prod: your Vercel domain. Used for auth + payment callbacks

# ── Scheduler (Vercel Cron) ───────────────────────────────────
# Protects cron API routes so only the scheduler can trigger them. SERVER-ONLY.
# (Skip if you run jobs purely via Supabase pg_cron instead.)
CRON_SECRET=generate-a-long-random-string

# NOTE: In production, set all these in the Vercel project settings (Environment
# Variables), not in a committed file. This .env.example is the reference only.

# ── Supabase ──────────────────────────────────────────────────
# URL + anon key are safe on the client. Service-role key is SERVER-ONLY.
NEXT_PUBLIC_SUPABASE_URL=https://wfkeyjukkoktubeqvjch.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Indma2V5anVra29rdHViZXF2amNoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk3NzgxMTQsImV4cCI6MjA5NTM1NDExNH0.D0abIA-qDOEYySIsnkbtVYsr39S6a6Ri-qWWPRUFfkU
# Mobile (Expo) reads the same values under EXPO_PUBLIC_*:
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Indma2V5anVra29rdHViZXF2amNoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk3NzgxMTQsImV4cCI6MjA5NTM1NDExNH0.D0abIA-qDOEYySIsnkbtVYsr39S6a6Ri-qWWPRUFfkU
# DANGER: server-only. Bypasses RLS. Never expose to any client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Indma2V5anVra29rdHViZXF2amNoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3OTc3ODExNCwiZXhwIjoyMDk1MzU0MTE0fQ.nLPd9q7msBJWG2VcnowLueZmcffoX4Xv1y5UfgbNVI8
# ── Claude API (AI layer: Gujarati typesetting, genre tagging, pull-quote, જોડણી check) ─
# SERVER-ONLY.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7                  # adjust as needed

# ── Razorpay (LISTING FEE ONLY — never member-to-member, never commission) ─
# Key id may be public for checkout; secret + webhook secret are SERVER-ONLY.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Phone OTP ─────────────────────────────────────────────────
# Preferred: configure the SMS/OTP provider inside the Supabase dashboard
# (Auth → Phone). If you instead run custom OTP via MSG91, set these (SERVER-ONLY):
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_OTP_TEMPLATE_ID=your-template-id
# MSG91_SENDER_ID=your-sender-id

# ── Email (REQUIRED for the weekly professional digest + renewal reminders) ─
# SERVER-ONLY.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="Nagarsetu <no-reply@your-domain>"

# ── WhatsApp (REQUIRED for the weekly professional broadcast) ─
# Proactive sends need APPROVED templates + member opt-in. SERVER-ONLY.
WHATSAPP_ACCESS_TOKEN=your-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# ── Facebook share (OPTIONAL) ─────────────────────────────────
# Plain share dialog/links need no secret. Only for FB Share SDK if used:
# NEXT_PUBLIC_FACEBOOK_APP_ID=your-fb-app-id

# ── Notes ─────────────────────────────────────────────────────
# • Listing-fee AMOUNT is product config — keep it in the DB, not here
#   (it's an Open Decision in MEMORY.md), so it can change without a redeploy.
# • Add real .env files to .gitignore. Commit ONLY this .env.example.
