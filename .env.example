# ──────────────────────────────────────────────────────────────
# Jay Hatkesh (Nagarsetu) — .env.example
# Copy to .env.local (per-app: apps/web/.env.local + apps/mobile/.env.local)
# and fill in. NEVER commit real values — both .env and .env.local are
# .gitignored on purpose.
#
# Naming rules:
#   NEXT_PUBLIC_*  → exposed to the browser (web/Next.js). Safe-to-public only.
#   EXPO_PUBLIC_*  → exposed to the mobile client (Expo). Safe-to-public only.
#   everything else → SERVER-ONLY. Never ship to any client bundle.
#
# ⚠ If you EVER suspect a key has been committed: rotate it immediately,
#   not just remove from the file. Git history retains content forever.
# ──────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
# NOTE: do NOT set NODE_ENV manually. Next.js + Vercel set it for you
# (development for `next dev`, production for `next build` / Vercel
# production deploys, test for test runs). Setting NODE_ENV=development
# in a production build loads the React dev bundle and breaks prerender.
NEXT_PUBLIC_APP_URL=http://localhost:3000        # in prod: https://jayhatkesh.in (Vercel). Used for auth + payment callbacks

# ── Scheduler (Vercel Cron) ───────────────────────────────────
# Protects cron API routes so only the scheduler can trigger them. SERVER-ONLY.
# (Skip if you run jobs purely via Supabase pg_cron instead.)
CRON_SECRET=generate-a-long-random-string

# NOTE: In production, set all these in the Vercel project settings (Environment
# Variables), not in a committed file. This .env.example is the reference only.

# ── Supabase ──────────────────────────────────────────────────
# URL + publishable key are safe on the client. Secret key is SERVER-ONLY.
# Use the NEW key format (sb_publishable_…, sb_secret_…), not the legacy
# JWT-style anon/service_role keys — those were disabled on 2026-05-27.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Mobile (Expo) reads the same values under EXPO_PUBLIC_*:
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# DANGER: server-only. Bypasses RLS. Never expose to any client bundle.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Claude API (AI layer: Gujarati typesetting, genre tagging, pull-quote, જોડણી check) ─
# SERVER-ONLY.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7                  # adjust as needed

# ── Razorpay (LISTING FEE ONLY — never member-to-member, never commission) ─
# Key id may be public for checkout; secret + webhook secret are SERVER-ONLY.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Phone OTP via Meta WhatsApp (Auth Hook → /api/auth-hooks/send-otp) ─
# Sign-in delivery channel — see WHATSAPP.md for the full Meta prep flow.
# This secret comes from Supabase dashboard (Auth → Hooks → Send SMS → enable
# → copy generated secret). Format: `v1,whsec_<base64>`. SERVER-ONLY.
SUPABASE_AUTH_HOOK_SECRET=v1,whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (REQUIRED for the weekly professional digest + renewal reminders) ─
# SERVER-ONLY.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM="Jay Hatkesh <no-reply@jayhatkesh.in>"

# ── Meta App (parent app hosting the WhatsApp + FB products) ──
# From Meta App Dashboard → Settings → Basic. App ID is public-ish; App Secret
# is SERVER-ONLY + sensitive. Used for webhook payload signature verification
# (X-Hub-Signature-256) and appsecret_proof on Graph API calls. Set the REAL
# values in Vercel env (mark App Secret "Sensitive"), never in a committed file.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────
# Used for BOTH the OTP send (Authentication template) and proactive sends
# (Utility templates: lead nudge; Marketing template: fortnightly digest).
# All proactive sends require an APPROVED template + member opt-in.
# SERVER-ONLY for all credentials.
WHATSAPP_ACCESS_TOKEN=your-permanent-system-user-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# Authentication template (the OTP send). Submit + get approved before the
# sign-in flow works for real phones. Name + language must match the
# approved template exactly. Pin Graph API version to a known-good release.
WHATSAPP_AUTH_TEMPLATE_NAME=nagarsetu_otp
WHATSAPP_AUTH_TEMPLATE_LANG=en
WHATSAPP_GRAPH_API_VERSION=v21.0

# ── Facebook share (OPTIONAL) ─────────────────────────────────
# Plain share dialog/links need no secret. Only for FB Share SDK if used:
# NEXT_PUBLIC_FACEBOOK_APP_ID=your-fb-app-id

# ── Notes ─────────────────────────────────────────────────────
# • Listing-fee AMOUNT is product config — keep it in the DB, not here
#   (it's an Open Decision in MEMORY.md), so it can change without a redeploy.
# • Add real .env files to .gitignore. Commit ONLY this .env.example.
