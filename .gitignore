# ── Secrets (NEVER commit) ────────────────────────────────────
# keep the template, ignore real env files
.env
.env.*
!.env.example
*.pem
*.key
# Expo / EAS signing material
*.jks
*.p8
*.p12
*.mobileprovision
google-services.json
GoogleService-Info.plist
# Downloaded credential/key exports (e.g. Razorpay key CSV) — store these in a
# password manager + Vercel env, never in the repo folder.
rzp-key*.csv
*-keys.csv
*secret*.csv

# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/releases

# ── Next.js (web) ─────────────────────────────────────────────
.next/
out/
build/
dist/
.vercel
.turbo

# ── Expo / React Native (mobile) ──────────────────────────────
.expo/
.expo-shared/
web-build/
*.orig.*

# ── Supabase ──────────────────────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Logs & misc ───────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
coverage/
.cache/

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp
.vscode/*
!.vscode/extensions.json
